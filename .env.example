# OpenAI (optional)
# - OPENAI_API_KEY가 없으면 mock provider로 동작합니다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT=60
OPENAI_MAX_TOKENS=1200
OPENAI_TEMPERATURE=0.2

# 국가법령정보 Open API (optional)
# - LAW_API_KEY는 가이드에서 'OC'로 표기되는 API 인증값입니다.
# - LAW_API_ENABLED=true 이고 LAW_API_KEY가 설정된 경우에만 호출합니다.
LAW_API_ENABLED=false
LAW_API_KEY=
LAW_API_BASE_URL=https://www.law.go.kr/DRF
LAW_API_TIMEOUT=20
LAW_API_RETRY=2
